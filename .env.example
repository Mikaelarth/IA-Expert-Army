# ============================================================
# IA-Expert-Army — Variables d'environnement (template)
# ============================================================
# Copie ce fichier en .env et remplis les valeurs.
# Le .env est gitignoré, ne sera jamais committé.
#
# Bascule v0.4.0 (ADR-025) : LLM via Ollama local, plus d'API Anthropic.
# Aucune clé API requise, aucun coût USD : tout tourne en local.
# Pré-requis : Ollama installé (https://ollama.com), daemon démarré.

# --- Backend LLM : Ollama local ---
# Endpoint OpenAI-compatible exposé par Ollama. Par défaut localhost:11434.
# Adapte si tu lances Ollama sur un autre port / une autre machine du LAN.
OLLAMA_BASE_URL=http://localhost:11434/v1
# Placeholder requis par le SDK openai (Ollama ignore la valeur).
OLLAMA_API_KEY=ollama
# Timeout par appel — généreux (10 min) car les modèles locaux 32B
# peuvent prendre 2-5 min à générer 16k tokens sans GPU costaud.
OLLAMA_TIMEOUT_SECONDS=600

# --- Modèles Ollama par tier ---
# Mapping recommandé (ADR-025). Tags exacts visibles via `ollama list`.
# Pull avant le premier run :
#   ollama pull qwen2.5:32b
#   ollama pull qwen2.5-coder:32b
#   ollama pull qwen2.5:14b
#
# Stratégique : Architect, ChiefOrchestrator, QualityGuardian,
# BusinessAnalyst, ResearchLead, ContentStrategist.
MODEL_STRATEGIC=qwen2.5:32b
# Opérationnel : BackendDeveloper, CodeReviewer, SecurityAuditor,
# Copywriter, Editor, DocumentSynthesizer, ResearchReviewer,
# LegalReviewer, ProjectManager, SkillExtractor, MetaDecomposer.
MODEL_OPERATIONAL=qwen2.5-coder:32b
# Bulk : TechWatch (findings factuels), plus rapide / moins gourmand.
MODEL_BULK=qwen2.5:14b

# --- Limites & garde-fous ---
# Backend local = pas de coût USD. Le BudgetController est no-op
# si daily_budget_usd <= 0. Mettre une valeur > 0 réactive le cap
# (utile si tu veux capper en proxy d'un cap tokens/temps externe).
DAILY_BUDGET_USD=0.0
MAX_AGENT_TURNS=20
MAX_CONCURRENT_AGENTS=5
CIRCUIT_BREAKER_ERROR_RATE=0.3

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=console  # 'console' ou 'json'

# --- Infrastructure (Phase 3+) ---
REDIS_URL=redis://localhost:6379/0
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_DB_PATH=./data/memory.db

# --- Langfuse observabilité (Phase 3+) ---
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Sandbox Docker (Phase 3+) ---
SANDBOX_IMAGE=python:3.12-slim
SANDBOX_NETWORK=none
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT=512m
# Kill-switch sandbox (Sprint GGG.1) :
# - True (défaut)  : run_mission --validate appelle Docker
# - False          : skip silencieux (utile sur VPS sans Docker ou dev rapide)
ENABLE_SANDBOX=true

# --- Profil VPS (Sprint GGG) ---
# Indicateur de capacité hardware pour diagnostic dans les digests/runbook.
# Valeurs : vps1 (8Go), vps2 (12Go), vps3 (24Go), local (poste dev), "" (auto)
VPS_PROFILE=local

# --- Notifications mobiles (Sprint HHH) ---
NOTIFY_WEBHOOK_URL=
# auto = détecte depuis l'URL. Override possible : discord|slack|telegram|generic|none
NOTIFY_BACKEND=auto

# --- v0.7.0 — LLM Classifier (opt-in, fallback heuristique automatique) ---
# True : MissionRouter utilise Qwen 14B pour trancher les missions ambiguës.
# False (défaut) : héuristique mots-clés uniquement (rapide, déterministe).
USE_LLM_CLASSIFIER=false

# --- v0.8.0 F4 — Hot-reload des prompts système (opt-in) ---
# True : BaseAgent re-lit son prompt disque AVANT chaque appel LLM
# (~10 ms overhead, négligeable vs 30s+ d'inférence). Permet d'itérer sur
# prompts/**/*.md sans redémarrer Streamlit/CLI.
# False (défaut) : prompt caché au boot, cohérence stricte en production.
HOT_RELOAD_PROMPTS=false
