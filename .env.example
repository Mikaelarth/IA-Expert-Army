# ============================================================
# IA-Expert-Army — Variables d'environnement (template)
# ============================================================
# Copie ce fichier en .env et remplis les valeurs.
# Le .env est gitignoré, ne sera jamais committé.

# --- Anthropic API ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Modèles Claude par tier ---
# Stratégique : Orchestrator, Quality Guardian, agents critiques
MODEL_STRATEGIC=claude-opus-4-7
# Opérationnel : agents codeurs, analystes, créatifs
MODEL_OPERATIONAL=claude-sonnet-4-6
# Bulk : tâches volumineuses simples (classification, résumés courts)
MODEL_BULK=claude-haiku-4-5-20251001

# --- Limites & garde-fous ---
# 50 USD par défaut pour la phase de développement actif (~25-50 missions/jour).
# Réduire à 10-20 USD en production une fois la stack stabilisée.
DAILY_BUDGET_USD=50.0
MAX_AGENT_TURNS=20
MAX_CONCURRENT_AGENTS=5
CIRCUIT_BREAKER_ERROR_RATE=0.3

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=console  # 'console' ou 'json'

# --- Infrastructure (Phase 3+) ---
REDIS_URL=redis://localhost:6379/0
CHROMA_PERSIST_DIR=./data/chroma
SQLITE_DB_PATH=./data/memory.db

# --- Langfuse observabilité (Phase 3+) ---
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Sandbox Docker (Phase 3+) ---
SANDBOX_IMAGE=python:3.12-slim
SANDBOX_NETWORK=none
SANDBOX_TIMEOUT_SECONDS=30
SANDBOX_MEMORY_LIMIT=512m
# Kill-switch sandbox (Sprint GGG.1) :
# - True (défaut)  : run_mission --validate appelle Docker
# - False          : skip silencieux (utile sur VPS sans Docker ou dev rapide)
ENABLE_SANDBOX=true

# --- Profil VPS (Sprint GGG) ---
# Indicateur de capacité hardware pour diagnostic dans les digests/runbook.
# Valeurs : vps1 (8Go), vps2 (12Go), vps3 (24Go), local (poste dev), "" (auto)
VPS_PROFILE=local

# --- Notifications mobiles (Sprint HHH) ---
# Webhook pour recevoir digest quotidien + alertes critiques sur ton téléphone.
# Vide = désactivé (no-op silencieux).
#
# Exemples :
#   Discord  : NOTIFY_WEBHOOK_URL=https://discord.com/api/webhooks/<ID>/<TOKEN>
#   Slack    : NOTIFY_WEBHOOK_URL=https://hooks.slack.com/services/<TXX>/<BXX>/<XXX>
#   Telegram : NOTIFY_WEBHOOK_URL=https://api.telegram.org/bot<TOKEN>/sendMessage?chat_id=<CHAT_ID>
#   Generic  : NOTIFY_WEBHOOK_URL=https://<n8n|pipedream|zapier>/webhook/...
NOTIFY_WEBHOOK_URL=
# auto = détecte depuis l'URL. Override possible : discord|slack|telegram|generic|none
NOTIFY_BACKEND=auto
