# Secrets — ne jamais committer
.env
.env.local
.env.*.local
*.key
*.pem
secrets/

# Données runtime
data/memory.db
data/memory.db-*
data/chroma/
data/episodes/
data/backups/
# FileMemory (Phase 1) : épisodes + missions + working
data/memory/
# BudgetController state (Phase 6)
data/budget_state.json
# Killswitch sentinel (Phase 6)
data/.killswitch
# Autonomous run reports (Sprint C / Phase 6) — un témoin historique reste
# committé pour la posterité ; les nouveaux rapports sont locaux.
data/autonomous_runs/*.md
!data/autonomous_runs/20260514T131532.md
# Backups (Sprint BBB) — archives locales, jamais committées (volume + secrets potentiels)
data/backups/
# Approvals (Sprint CCC) — état runtime local, decisions horodatées par user
# Note : la policy.yml SI on la commit ferait sens (politique partagée équipe),
# mais pour v1 chacun la sienne en local.
data/approvals/
# Probes (Session 5, v0.5.0) — les fichiers .md de probes sont des artefacts
# pédagogiques qu'on commit (1 par probe). Le sous-dossier _tmp_memory/ que
# probe_reviewer.py crée pour isolation est un déchet runtime — pas commit.
data/probes/_tmp_memory/
# GUI Streamlit (Session 8) — log capturé localement quand on debug le serveur.
gui-server.log
*.log
logs/

